{
  "buildCommand": "echo \"{\\\"SUPABASE_URL\\\":\\\"$SUPABASE_URL\\\",\\\"SUPABASE_ANON_KEY\\\":\\\"$SUPABASE_ANON_KEY\\\",\\\"API_BASE_URL\\\":\\\"$API_BASE_URL\\\",\\\"GOOGLE_WEB_CLIENT_ID\\\":\\\"$GOOGLE_WEB_CLIENT_ID\\\",\\\"GOOGLE_IOS_CLIENT_ID\\\":\\\"$GOOGLE_IOS_CLIENT_ID\\\"}\" > config.prod.json && flutter/bin/flutter build web --release --dart-define-from-file=config.prod.json",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
