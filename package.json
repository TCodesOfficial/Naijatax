{
  "name": "naijatax",
  "version": "1.0.0",
  "private": true,
  "description": "NaijaTax Enlighten - Tax companion app",
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && flutter run --dart-define-from-file=config.dev.json",
    "dev:web": "cd client && flutter run -d chrome --dart-define-from-file=.env",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "build:server": "cd server && npm run build",
    "build:client": "cd client && flutter build apk --dart-define-from-file=.env",
    "build:web": "cd client && flutter build web --dart-define-from-file=config.dev.json",
    "analyze": "cd client && dart analyze",
    "lint:server": "cd server && tsc --noEmit",
    "db:migrate": "cd server && npm run prisma:migrate",
    "db:seed": "cd server && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
