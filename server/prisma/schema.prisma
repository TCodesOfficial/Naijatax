generator client {
  provider = "prisma-client-js"
}

datasource db {
  // set provider to postgress
  provider = "postgresql"
}

model User {
  id           String        @id // Matches Supabase Auth user ID (UUID)
  email        String?       @unique // Optional for phone-based auth
  phone        String?       @unique // Phone number for phone-based auth
  displayName  String?       @map("display_name") // User's display name
  avatarUrl    String?       @map("avatar_url") // User's profile photo URL
  onboarded    Boolean       @default(false) // Whether user has completed onboarding
  role         String        @default("USER") // USER or ADMIN
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  taxProfiles  TaxProfile[]
  forumTopics  ForumTopic[]
  forumReplies ForumReply[]
  quizScores   QuizScore[]
  chatSessions ChatSession[]

  @@map("users")
}

model TaxProfile {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyIncome Decimal  @map("monthly_income") @db.Decimal(15, 2)
  annualGross   Decimal  @map("annual_gross") @db.Decimal(15, 2)
  rentPaid      Decimal  @map("rent_paid") @db.Decimal(15, 2)
  pensionRate   Decimal  @map("pension_rate") @db.Decimal(4, 2)
  computedTax   Decimal  @map("computed_tax") @db.Decimal(15, 2)
  netIncome     Decimal  @map("net_income") @db.Decimal(15, 2)
  isExempt      Boolean  @default(false) @map("is_exempt")
  citExemption  String   @default("EXEMPT") @map("cit_exemption") // EXEMPT, TAXABLE_15, TAXABLE_20 etc.
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("tax_profiles")
}

model VatItem {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  status    String // STANDARD, ZERO_RATED, EXEMPT
  rate      Decimal  @db.Decimal(4, 2)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("vat_items")
}

model QuizQuestion {
  id           String   @id @default(cuid())
  question     String
  options      Json // Array of strings ["Option A", "Option B", ...]
  correctIndex Int      @map("correct_index")
  explanation  String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("quiz_questions")
}

model QuizScore {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score          Int
  totalQuestions Int      @map("total_questions")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("quiz_scores")
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  messages  ChatMessage[]

  @@index([userId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // user, assistant, system
  content   String
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model ForumTopic {
  id        String       @id @default(cuid())
  title     String
  content   String
  tags      Json // Array of tags ["PAYE", "VAT", ...]
  userId    String       @map("user_id")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  replies   ForumReply[]
  upVotes   Int          @default(0)
  downVotes Int          @default(0)

  @@index([userId, createdAt])
  @@map("forum_topics")
}

model ForumReply {
  id         String     @id @default(cuid())
  topicId    String     @map("topic_id")
  topic      ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  content    String
  userId     String     @map("user_id")
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now()) @map("created_at")
  isAccepted Boolean    @default(false) @map("is_accepted")

  @@index([topicId, createdAt])
  @@map("forum_replies")
}

model TaxArticle {
  id         String   @id @default(cuid())
  title      String
  summary    String
  content    String
  source     String // FIRS, NRS, KPMG etc.
  category   String? // NTA_2025, PAYE, CIT, VAT, COMPLIANCE
  url        String?
  isFeatured Boolean  @default(false) @map("is_featured")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("tax_articles")
}
